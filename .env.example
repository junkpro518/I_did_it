# Telegram
TELEGRAM_BOT_TOKEN=put-bot-token-from-BotFather-here
TELEGRAM_CHAT_ID=

# Notion
NOTION_TOKEN=secret_xxx
NOTION_DATABASE_ID=

# Notion property names (override only if your DB uses different names)
NOTION_TITLE_PROPERTY=Name
NOTION_DATE_PROPERTY=Date
NOTION_STATUS_PROPERTY=Status
NOTION_TYPE_PROPERTY=Type
NOTION_VALUE_PROPERTY=Value
NOTION_NOTE_PROPERTY=Note

# Notion status values (in your Status select)
NOTION_STATUS_DONE=Done
NOTION_STATUS_MISSED=Missed
NOTION_STATUS_POSTPONED=Postponed

# Notion Type select values (these tell the bot HOW to ask each task)
TYPE_BOOLEAN=Boolean
TYPE_NUMBER=Number
TYPE_RATING=Rating
TYPE_TEXT=Text

# Schedule (24h clock)
TIMEZONE=Asia/Riyadh
DAILY_HOUR=22
DAILY_MINUTE=0
